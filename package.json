{
  "name": "raw-image-viewer",
  "displayName": "Raw Image Viewer",
  "description": "A binary RAW image viewer extension for Visual Studio Code.",
  "publisher": "temeedeeki",
  "author": {
    "name": "temeedeeki"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/temeedeeki/raw-image-viewer"
  },
  "license": "MIT",
  "version": "0.0.1",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "raw-image-viewer.rawImage",
        "displayName": "Raw Image Viewer",
        "selector": [
          {
            "filenamePattern": "*.raw"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "compile": "npm run check-types && npm run lint && npm run build",
    "dev": "npm-run-all -p watch:build watch:types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch": "npm run dev",
    "watch:build": "node esbuild.js --watch",
    "watch:types": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && npm run build:prod",
    "package:vsix": "npx @vscode/vsce package --no-dependencies",
    "compile-tests": "tsc --project tsconfig.test.json",
    "watch-tests": "tsc --watch --project tsconfig.test.json",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
